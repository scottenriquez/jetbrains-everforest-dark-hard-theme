<idea-plugin>
    <id>xxx.scottie.everforestdarker</id>
    <name>Everforest Darker (Islands)</name>
    <vendor url="https://scottie.la">Scottie Enriquez</vendor>

    <description><![CDATA[
        A darker port of the
        <a href="https://github.com/sainnhe/everforest">Everforest</a> color scheme.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <themeProvider id="xxx.scottie.everforestdarker.theme"
                       path="/theme/EverforestDarker.theme.json"
                       targetUi="islands"/>
    </extensions>
</idea-plugin>
